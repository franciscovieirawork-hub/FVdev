---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import Loader from '../components/Loader.astro';

// Mock Data - Projects
const projectsData = {
  projects: [
    {
      id: 3,
      title: 'DevDrawer',
      shortDescription:
        'A full-stack app to visually plan and organize software projects',
      description: [
        'DevDrawer is a full stack web application designed for developers and teams to visually plan, structure, and organize software projects.',
        'It helps you break down work into boards, sections, and items, keeping technical decisions, tasks, and architecture in one structured place.',
        'The goal is to replace scattered docs and ad‑hoc notes with a focused workspace tailored to engineering workflows.'
      ],
      features: [
        'Project- and board-based organization for development work',
        'Hierarchical structure for sections, tasks, and notes',
        'Modern UI optimized for developers',
        'Built with a TypeScript-first mindset'
      ],
      technologies: ['TypeScript', 'Full-stack web app'],
      repoUrl: 'https://github.com/franciscovieirawork-hub/devdrawer',
      liveUrl: 'https://dev-drawer.vercel.app'
    },
    {
      id: 4,
      title: 'YourCalculator (BETA)',
      shortDescription:
        'Fiscal and financial calculators tailored for Portugal',
      description: [
        'YourCalculator is a collection of fiscal and financial calculators focused on the Portuguese context, helping users quickly estimate taxes and other financial values.',
        'The web app is designed to be simple and fast to use, surfacing just the key inputs and outputs needed for everyday financial decisions.',
        'It is deployed as a standalone web experience so it is easy to share and use from any device.'
      ],
      features: [
        'Multiple calculators for Portuguese fiscal and financial scenarios',
        'Simple UX optimized for quick inputs and clear results',
        'Continuously evolving as new calculators and rules are added'
      ],
      technologies: ['TypeScript', 'React', 'Web app'],
      repoUrl: 'https://github.com/franciscovieirawork-hub/yourCalculator',
      liveUrl: 'https://atuacalculadora.vercel.app/'
    },
    {
      id: 5,
      title: 'AboutF1 (Work in progress still)',
      shortDescription:
        'Web and native app about Formula 1, tracks, teams, and cars',
      description: [
        'AboutF1 is a project focused on Formula 1, bringing together information about live events, tracks, pits, teams, cars, and more.',
        'The project targets both web and native (iOS & Android) platforms, exploring how to share logic and UX patterns across experiences.',
        'It is a playground for experimenting with motorsport data, rich UI, and multi-platform application architecture.'
      ],
      features: [
        'Centralized hub for Formula 1 information',
        'Support for both web and native app experiences',
        'Focus on rich, visually engaging UI for motorsport fans'
      ],
      technologies: ['TypeScript', 'Web & native app'],
      repoUrl: 'https://github.com/franciscovieirawork-hub/aboutf1',
      liveUrl: null
    },
    {
      id: 6,
      title: 'FVDev Portfolio',
      shortDescription:
        'Personal website and portfolio built with Astro and React',
      description: [
        'FVDev is this personal website and portfolio, built to showcase projects, experience, and links in a minimal, high-contrast interface.',
        'The site is built with Astro and React, focusing on fast performance, clean typography, and a content structure tailored to developers.',
        'It serves as a central hub for your professional journey, open-source work, and ways to get in touch.'
      ],
      features: [
        'Fast, minimal and responsive portfolio',
        'Astro + React architecture with modern tooling',
        'Dedicated pages for experience, GitHub projects, and contact'
      ],
      technologies: ['Astro', 'React', 'TypeScript', 'CSS'],
      repoUrl: 'https://github.com/franciscovieirawork-hub/FVdev',
      liveUrl: 'https://f-vdev.vercel.app'
    },
    {
      id: 1,
      title: 'useCall & useCallGraphQL',
      shortDescription:
        'Powerful and customizable React hooks for REST API and GraphQL calls',
      description: [
        'A pair of React hooks designed to make REST API and GraphQL requests predictable, strongly typed, and easy to reuse across your application.',
        'useCall handles REST endpoints with built-in loading, error, and success states, plus automatic request deduplication and cancellation.',
        'useCallGraphQL focuses on GraphQL queries and mutations, supporting both raw string queries and DocumentNode, with first-class variables and operation names.',
        'Both hooks are written in TypeScript and are ideal for projects that need a consistent, reusable data-fetching layer without adopting a full-blown data library.'
      ],
      features: [
        'Smart cache that prevents duplicate requests and supports refetching',
        'Strong TypeScript generics for request and response types',
        'Configurable success and error callbacks for side effects',
        'Request cancellation and automatic cleanup on unmount',
        'GraphQL support with variables and operation names',
        'Custom headers, credentials, and fetch options per call'
      ],
      technologies: ['React', 'TypeScript', 'GraphQL', 'REST API', 'Vite'],
      repoUrl: 'https://github.com/franciscovieirawork-hub/useCall_useCallGraphQL',
      liveUrl: null
    },
    {
      id: 2,
      title: 'React Card Component System',
      shortDescription:
        'Default and expandable card components built with React and TypeScript',
      description: [
        'A small React component system that provides opinionated, accessible card components for modern UIs.',
        'It includes a default card for simple content blocks and an expandable card for sections that can be toggled open and closed.',
        'The system is written in TypeScript and is built to be copy–paste friendly, so you can adapt it to your own design system.',
        'Ideal for dashboards, settings pages, and any layout that needs clean, reusable content blocks.'
      ],
      features: [
        'Default and expandable card variants',
        'Controlled and uncontrolled expand / collapse behavior',
        'TypeScript-first API with clear prop types',
        'Responsive layout and smooth hover / focus states',
        'Easy to integrate into existing React projects'
      ],
      technologies: ['React', 'TypeScript', 'Vite'],
      repoUrl: 'https://github.com/franciscovieirawork-hub/react-card',
      liveUrl: null
    },
  ]
};

---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico">
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Projects - FVDev</title>
    <meta name="description" content="My open-source projects and work" />
    <ViewTransitions />
  </head>
  <body>
    <Loader />
    <main>
      <div class="container">
        <!-- Back Button -->
        <a href="/" class="back-btn">← back</a>

        <!-- GitHub Link -->
        <div class="github-link-top">
          <a href="https://github.com/franciscovieirawork-hub" target="_blank" rel="noopener noreferrer" class="github-btn">
            → visit my github
          </a>
        </div>

        <!-- Page Header -->
        <section class="projects-header">
          <h1>projects</h1>
          <p class="subtitle">open-source projects and experiments</p>
        </section>

        <!-- Projects List -->
        <section class="projects-list">
          {projectsData.projects.map((project) => (
            <div class="project-card">
              <div class="project-header">
                <h2 class="project-title">{project.title}</h2>
                <p class="project-short-desc">{project.shortDescription}</p>
              </div>

              <div class="project-description">
                {project.description.map((para) => (
                  <p>{para}</p>
                ))}
              </div>

              <div class="features-section">
                <h3>key features</h3>
                <ul class="features-list">
                  {project.features.map((feature) => (
                    <li>✓ {feature}</li>
                  ))}
                </ul>
              </div>

              <div class="technologies">
                <h3>tech stack</h3>
                <div class="tech-tags">
                  {project.technologies.map((tech) => (
                    <span class="tech-tag">{tech}</span>
                  ))}
                </div>
              </div>

              <div class="project-actions">
                <a href={project.repoUrl} target="_blank" rel="noopener noreferrer" class="action-button repo-btn">
                  → view repository
                </a>
                {project.liveUrl && (
                  <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="action-button demo-btn">
                    → live demo
                  </a>
                )}
              </div>
            </div>
          ))}
        </section>

        <!-- CTA Section -->
        <section class="cta-section">
          <p>Interested in my work? Check out more on GitHub.</p>
          <a href="https://github.com/franciscovieirawork-hub" target="_blank" rel="noopener noreferrer" class="cta-button">
            → view all projects
          </a>
        </section>
      </div>
    </main>
  </body>
</html>

<style>
  main {
    min-height: 100vh;
    padding: 40px 20px;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  /* Back Button */
  .back-btn {
    display: inline-block;
    margin-bottom: 20px;
    color: #999999;
    text-decoration: none;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    transition: all 0.2s ease;
    border-bottom: 1px solid transparent;
  }

  .back-btn:hover {
    color: #ffff00;
    border-bottom: 1px solid #ffff00;
  }

  /* GitHub Link Top */
  .github-link-top {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 40px;
  }

  .github-btn {
    color: #ffff00;
    text-decoration: none;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    transition: all 0.2s ease;
    border-bottom: 1px solid transparent;
  }

  .github-btn:hover {
    border-bottom: 1px solid #ffff00;
    opacity: 0.8;
  }

  /* Projects Header */
  .projects-header {
    margin-bottom: 60px;
    padding-bottom: 30px;
    border-bottom: 1px solid #333333;
  }

  .projects-header h1 {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 15px;
    line-height: 1.2;
  }

  .subtitle {
    font-size: 1.1rem;
    color: #999999;
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  /* Projects List */
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 50px;
    margin-bottom: 60px;
  }

  .project-card {
    padding: 40px;
    border: 1px solid #333333;
    border-radius: 4px;
    background-color: rgba(255, 255, 255, 0.01);
    transition: all 0.2s ease;
  }

  .project-card:hover {
    border-color: #ffff00;
    background-color: rgba(255, 255, 0, 0.03);
  }

  .project-header {
    margin-bottom: 25px;
  }

  .project-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.01em;
    margin: 0 0 10px 0;
  }

  .project-short-desc {
    font-size: 1rem;
    color: #ffff00;
    font-weight: 600;
    margin: 0;
  }

  .project-description {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 30px;
  }

  .project-description p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: #e0e0e0;
    margin: 0;
    letter-spacing: -0.01em;
  }

  /* Features Section */
  .features-section {
    margin-bottom: 30px;
  }

  .features-section h3 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin: 0 0 15px 0;
    color: #cccccc;
    text-transform: uppercase;
  }

  .features-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 0;
    margin: 0;
  }

  .features-list li {
    font-size: 0.9rem;
    color: #999999;
    letter-spacing: 0.01em;
  }

  .features-list li:hover {
    color: #ffff00;
  }

  /* Technologies Section */
  .technologies {
    margin-bottom: 30px;
  }

  .technologies h3 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin: 0 0 15px 0;
    color: #cccccc;
    text-transform: uppercase;
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tech-tag {
    display: inline-block;
    background-color: #1a1a1a;
    border: 1px solid #333333;
    color: #cccccc;
    padding: 6px 12px;
    border-radius: 3px;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    transition: all 0.2s ease;
  }

  .tech-tag:hover {
    border-color: #ffff00;
    color: #ffff00;
    background-color: rgba(255, 255, 0, 0.05);
  }

  /* Project Actions */
  .project-actions {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
  }

  .action-button {
    display: inline-block;
    background-color: transparent;
    border: 1px solid #333333;
    color: #cccccc;
    padding: 10px 20px;
    border-radius: 3px;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    transition: all 0.2s ease;
  }

  .action-button:hover {
    border-color: #ffff00;
    color: #ffff00;
    background-color: rgba(255, 255, 0, 0.05);
  }

  .repo-btn {
    flex: 1;
    min-width: 150px;
  }

  .demo-btn {
    flex: 1;
    min-width: 150px;
  }

  /* CTA Section */
  .cta-section {
    text-align: center;
    padding: 40px 0;
    border-top: 1px solid #333333;
  }

  .cta-section p {
    font-size: 1rem;
    color: #999999;
    margin-bottom: 20px;
    letter-spacing: 0.01em;
  }

  .cta-button {
    display: inline-block;
    background-color: transparent;
    border: 2px solid #ffff00;
    color: #ffff00;
    padding: 12px 30px;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    transition: all 0.2s ease;
  }

  .cta-button:hover {
    background-color: #ffff00;
    color: #0f0f0f;
  }

  /* Responsive */
  @media (max-width: 640px) {
    main {
      padding: 30px 20px;
    }

    .projects-header h1 {
      font-size: 2rem;
    }

    .subtitle {
      font-size: 0.95rem;
    }

    .project-card {
      padding: 25px;
    }

    .project-title {
      font-size: 1.3rem;
    }

    .projects-list {
      gap: 30px;
    }

    .project-actions {
      flex-direction: column;
    }

    .action-button {
      width: 100%;
    }
  }
</style>
